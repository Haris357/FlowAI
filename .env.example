# ===================================
# Firebase (Client SDK - public keys)
# ===================================
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ===================================
# Firebase Admin SDK (Server-side - SECRET)
# ===================================
# Option 1: Full JSON service account key
# FIREBASE_SERVICE_ACCOUNT_KEY=

# Option 2: Individual fields
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ===================================
# Admin Panel (admin.flowbooksai.com)
# ===================================
# Required to issue/verify admin JWTs. Must be at least 48 random chars.
# Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=

# ===================================
# LemonSqueezy (Payments)
# ===================================
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_PRO_VARIANT_ID=
LEMON_SQUEEZY_MAX_VARIANT_ID=
LEMON_SQUEEZY_PRO_YEARLY_VARIANT_ID=
LEMON_SQUEEZY_MAX_YEARLY_VARIANT_ID=
LEMON_SQUEEZY_TOKEN_STARTER_VARIANT_ID=
LEMON_SQUEEZY_TOKEN_POWER_VARIANT_ID=
LEMON_SQUEEZY_TOKEN_ENTERPRISE_VARIANT_ID=

# ===================================
# Email (Resend)
# ===================================
RESEND_API_KEY=
RESEND_FROM=Flowbooks <hello@flowbooksai.com>

# ===================================
# OpenAI
# ===================================
OPENAI_API_KEY=

# ===================================
# PostHog Analytics
# ===================================
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PERSONAL_API_KEY=

# ===================================
# App
# ===================================
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_URL=http://localhost:3000/support

# ===================================
# SEO / Search engine verification
# Paste the verification token (just the value, not the meta tag) from each console.
# ===================================
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=
NEXT_PUBLIC_FACEBOOK_DOMAIN_VERIFICATION=
