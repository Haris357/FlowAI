// Firestore Security Rules for Flowbooks
// Copy and paste these rules into your Firebase Console -> Firestore Database -> Rules

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if user is a member of a company
    function isMember(companyId) {
      return exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid));
    }

    // Helper: check if user is owner of a company
    function isOwner(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)).data.ownerId == request.auth.uid;
    }

    // Helper: check if user has access (owner OR member)
    function hasAccess(companyId) {
      return isOwner(companyId) || isMember(companyId);
    }

    // Helper: get member role
    function getMemberRole(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid)).data.role;
    }

    // Helper: check if user can write (owner, admin, or editor)
    function canWrite(companyId) {
      return isOwner(companyId) ||
        (isMember(companyId) && getMemberRole(companyId) in ['owner', 'admin', 'editor']);
    }

    // Users collection - users can only read/write their own document
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;

      // User settings subcollection
      match /settings/{settingId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      // User notifications subcollection
      match /notifications/{notificationId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      // User drafts subcollection (onboarding, etc.)
      match /drafts/{draftId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      // Subscription subcollection
      match /subscription/{subId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow write: if false; // Only admin SDK can write
      }

      // Usage tracking subcollection
      match /usage/{periodId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      // Daily usage tracking subcollection
      match /dailyUsage/{dateId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      // Company memberships (denormalized, read-only from client — written by API)
      match /companyMemberships/{companyId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }

      // Token purchases subcollection (read-only, historical data)
      match /tokenPurchases/{purchaseId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
      }

      // Billing history subcollection
      match /billingHistory/{eventId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow write: if false; // Only admin SDK can write
      }
    }

    // Invitations collection
    match /invitations/{invitationId} {
      // Invited user can read their invitations
      allow read: if isAuthenticated() &&
        resource.data.invitedEmail == request.auth.token.email;
      // Inviter can read and cancel their invitations
      allow read: if isAuthenticated() &&
        resource.data.invitedByUid == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.invitedByUid == request.auth.uid;
      // Only API can create invitations
      allow create, delete: if false;
    }

    // Announcements - read-only for users, write via admin SDK
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false; // Only admin SDK can write
    }

    // Support tickets - users create and read their own tickets
    match /supportTickets/{ticketId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Only admin (via server SDK) can update/delete tickets
      allow update, delete: if false;
    }

    // Feedback - users create and read their own feedback
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Only admin (via server SDK) can update/delete feedback
      allow update, delete: if false;
    }

    // Blog posts - publicly readable, only authenticated users can write (admin gated at app level)
    match /blogPosts/{postId} {
      allow read: if true;
      allow create, update, delete: if false; // Admin SDK only
    }

    // Testimonials - publicly readable, only authenticated users can write (admin gated at app level)
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create, update, delete: if false; // Admin SDK only
    }

    // Master Account Types collection - read-only for authenticated users, write only on first initialization
    match /accountTypes/{typeId} {
      // Allow read for all authenticated users (global/shared data)
      allow read: if isAuthenticated();

      // Allow write only if the document doesn't exist (initialization)
      allow create: if isAuthenticated();

      // Prevent updates and deletes to master data
      allow update, delete: if false;
    }

    // Companies collection
    match /companies/{companyId} {
      // Allow create if authenticated and setting self as owner
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;

      // Allow read if owner (uses resource.data — works with list queries)
      allow read: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      // Allow read if member (uses exists() — works for single getDoc calls)
      allow read: if isAuthenticated() && isMember(companyId);

      // Allow update by owner or admin/editor members
      allow update: if isAuthenticated() &&
        (resource.data.ownerId == request.auth.uid || canWrite(companyId));

      // Allow delete only by owner
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;

      // Members subcollection — readable by any member, writable by owner/admin
      match /members/{memberId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() &&
          (isOwner(companyId) ||
           (isMember(companyId) && getMemberRole(companyId) in ['owner', 'admin']));
      }

      // All data subcollections — read by any member, write by owner/admin/editor
      match /customers/{customerId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /vendors/{vendorId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /employees/{employeeId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /invoices/{invoiceId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /bills/{billId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /creditNotes/{creditNoteId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /debitNotes/{debitNoteId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /creditNoteApplications/{applicationId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /transactions/{transactionId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /bankTransactions/{transactionId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /accounts/{accountId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /bankAccounts/{accountId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /chartOfAccounts/{accountId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /accountSubtypes/{subtypeId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /journalEntries/{entryId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /quotes/{quoteId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /purchaseOrders/{poId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /recurringTransactions/{recurringId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /recurringTransactionLogs/{logId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /bankReconciliations/{recId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /payrollRuns/{runId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /salarySlips/{slipId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /messages/{messageId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      match /settings/{settingId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow write: if isAuthenticated() && canWrite(companyId);
      }

      // AI Conversation Memory - allow access if user owns the conversation
      match /conversations/{conversationId} {
        allow read: if isAuthenticated() && (
          resource.data.userId == request.auth.uid || hasAccess(companyId)
        );
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      }

      // Snapshot cache — server-side admin SDK only, deny all client access
      match /cache/{cacheId} {
        allow read, write: if false;
      }

      match /chatMessages/{messageId} {
        allow read: if isAuthenticated() && hasAccess(companyId);
        allow create: if isAuthenticated() &&
          request.resource.data.ownerId == request.auth.uid;
        allow update, delete: if isAuthenticated() &&
          resource.data.ownerId == request.auth.uid;
      }

      // Chat sessions collection
      match /chats/{chatId} {
        allow read: if isAuthenticated() &&
          resource.data.ownerId == request.auth.uid;
        allow create: if isAuthenticated() &&
          request.resource.data.ownerId == request.auth.uid;
        allow update, delete: if isAuthenticated() &&
          resource.data.ownerId == request.auth.uid;

        // Messages subcollection within chats
        match /messages/{messageId} {
          allow read, write: if isAuthenticated() &&
            get(/databases/$(database)/documents/companies/$(companyId)/chats/$(chatId)).data.ownerId == request.auth.uid;
        }
      }
    }
  }
}
