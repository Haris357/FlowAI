rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Chat attachments: authenticated users can read/write
    match /companies/{companyId}/chats/{chatId}/attachments/{fileName} {
      allow read, write: if request.auth != null;
    }

    // Bug report screenshots: authenticated users can upload their own
    match /reports/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
    }

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
